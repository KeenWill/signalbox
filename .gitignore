/target/

# devenv/direnv local state; the environment definition (devenv.nix,
# devenv.yaml, devenv.lock) is committed, local build state is not.
.devenv/
.direnv/
devenv.local.nix

# Local secrets and encryption materials — never committed.
.env
.env.*
*.agekey
keys.txt
# Decrypted sops output; encrypted sources are committed, plaintext is not.
*.decrypted.*
*.dec
*.dec.*
